# Pangolin configuration
# Generated by portless install wizard
# Docs: https://docs.pangolin.net/self-host/advanced/config-file
#
# Template vars: {PANGOLIN_DOMAIN} {BASE_DOMAIN} {ACME_EMAIL} {SECRET}
#

app:
  dashboard_url: "https://{PANGOLIN_DOMAIN}"
  log_level: "info"
  save_logs: false
  log_failed_attempts: true
  telemetry:
    anonymous_usage: true

server:
  external_port: 3000
  internal_port: 3001
  next_port: 3002
  integration_port: 3003
  internal_hostname: "pangolin"
  secret: "{SECRET}"
  session_cookie_name: "p_session_token"
  resource_access_token_param: "p_token"
  resource_access_token_headers:
    id: "P-Access-Token-Id"
    token: "P-Access-Token"
  resource_session_request_param: "p_session_request"
  trust_proxy: 1
  dashboard_session_length_hours: 720
  resource_session_length_hours: 720
  cors:
    origins:
      - "https://{PANGOLIN_DOMAIN}"
    methods:
      - "GET"
      - "POST"
      - "PUT"
      - "DELETE"
      - "PATCH"
    allowed_headers:
      - "X-CSRF-Token"
      - "Content-Type"
    credentials: false

domains:
  domain1:
    base_domain: "{BASE_DOMAIN}"
    cert_resolver: "letsencrypt"
    prefer_wildcard_cert: false

traefik:
  cert_resolver: "letsencrypt"
  http_entrypoint: "web"
  https_entrypoint: "websecure"
  additional_middlewares: []

gerbil:
  start_port: 51820
  clients_start_port: 21820
  base_endpoint: "{PANGOLIN_DOMAIN}"
  dns: "1.1.1.1"
  block_size: 24
  site_block_size: 30

rate_limits:
  global:
    window_minutes: 1
    max_requests: 100
  auth:
    window_minutes: 1
    max_requests: 10

email:
  smtp_host: ""
  smtp_port: 587
  no_reply: "no-reply@{BASE_DOMAIN}"
  name: "Pangolin"

flags:
  require_email_verification: false
  disable_signup_without_invite: true
  disable_user_create_org: false
  allow_raw_resources: true
