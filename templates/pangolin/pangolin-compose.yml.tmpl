# Pangolin stack — VPS docker-compose
# Generated by portless install wizard
# Pangolin: https://github.com/fosrl/pangolin
#
# Uses the Enterprise Edition image (ee-latest) — free for personal use and
# orgs under $100K revenue.  After first login, activate your free license at:
#   https://<your-pangolin-domain>/admin/license
# Get a free key at: https://app.pangolin.net → Licenses
#
# Template vars: (none — all config lives in config/config.yml and config/traefik/)
#

name: pangolin

services:

  # ─── Pangolin — tunnel server + admin dashboard ────────────────────────────
  pangolin:
    image: docker.io/fosrl/pangolin:ee-latest
    container_name: pangolin
    restart: unless-stopped
    volumes:
      - ./config:/app/config
    ports:
      - "127.0.0.1:3001:3001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/api/v1/"]
      interval: "10s"
      timeout: "10s"
      retries: 15

  # ─── Gerbil — WireGuard tunnel manager ────────────────────────────────────
  gerbil:
    image: docker.io/fosrl/gerbil:latest
    container_name: gerbil
    restart: unless-stopped
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --reachableAt=http://gerbil:3004
      - --generateAndSaveKeyTo=/var/config/key
      - --remoteConfig=http://pangolin:3001/api/v1/
    volumes:
      - ./config/:/var/config
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    ports:
      - "51820:51820/udp"
      - "21820:21820/udp"
      - "443:443"
      - "80:80"

  # ─── Traefik — TLS termination + routing ──────────────────────────────────
  traefik:
    image: docker.io/traefik:v3.6
    container_name: traefik
    restart: unless-stopped
    network_mode: service:gerbil
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --configFile=/etc/traefik/traefik_config.yml
    volumes:
      - ./config/traefik:/etc/traefik:ro
      - ./config/letsencrypt:/letsencrypt
      - ./config/traefik/logs:/var/log/traefik

networks:
  default:
    driver: bridge
    name: pangolin
